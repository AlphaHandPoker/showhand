# Frontend (Vercel) — set at BUILD time
VITE_SERVER_URL=https://your-app.up.railway.app

# Server (Railway)
PORT=3001
CLIENT_ORIGIN=https://your-app.vercel.app,https://www.pokerduel.app,https://pokerduel.app

# Railway Postgres — add a PostgreSQL plugin; Railway injects DATABASE_URL automatically
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Admin dashboard password (/admin on the frontend, /api/admin/* on the server)
ADMIN_PASSWORD=change-me-to-a-strong-password
