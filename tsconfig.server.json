{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./server/dist",
    "rootDir": ".",
    "declaration": false,
    "noEmit": false
  },
  "include": ["server/**/*", "shared/**/*", "src/game/**/*"]
}
